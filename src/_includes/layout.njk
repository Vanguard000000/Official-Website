<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
</head>
<body>
    <nav class="nav-container">
        <a href="{{ '/' | url }}" class="logo">PS</a>
        <div class="nav-right">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div class="menu-dropdown" id="menuDropdown">
                {% if navIndex == 0 %}
                <a href="#projects">Projects</a>
                {% endif %}
                {% set pages = [
                    { slug: '', label: 'Home' },
                    { slug: 'about', label: 'About' },
                    { slug: 'skills', label: 'Skills' },
                    { slug: 'portfolio', label: 'Portfolio' },
                    { slug: 'frc', label: 'FRC' },
                    { slug: 'goals', label: 'Goals' },
                    { slug: 'journey', label: 'Journey' },
                    { slug: 'contact', label: 'Contact' }
                ] %}
                {% for p in pages %}
                <a href="{{ ('/' + p.slug + '/') | url }}"{% if loop.index0 > 0 and loop.index0 == navIndex %} class="active"{% endif %}>{{ p.label }}</a>
                {% endfor %}
                <button id="darkModeToggle">☀️ Light Mode</button>
            </div>
        </div>
    </nav>

    {{ content | safe }}

    <footer class="footer">
        <div class="container">
            <p class="copyright">© 2026 Prakhar Singh</p>
        </div>
    </footer>

    <script src="{{ '/js/animation.js' | url }}"></script>
    <script src="{{ '/js/feature.js' | url }}"></script>
    <script src="{{ '/js/theme.js' | url }}"></script>
</body>
</html>
