<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    {% set navItems = [
        { url: "/", label: "Home" },
        { url: "/about", label: "About" },
        { url: "/skills", label: "Skills" },
        { url: "/portfolio", label: "Portfolio" },
        { url: "/frc", label: "FRC" },
        { url: "/goals", label: "Goals" },
        { url: "/journey", label: "Journey" },
        { url: "/contact", label: "Contact" }
    ] %}

    <nav class="nav-container">
        <a href="/" class="logo">PS</a>
        <div class="nav-right">
            <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="menu-dropdown" id="menuDropdown">
                {% for item in navItems %}
                <a href="{{ item.url }}"{% if loop.index0 == navIndex %} class="active"{% endif %}>{{ item.label }}</a>
                {% endfor %}
                <button id="darkModeToggle">☀️ Light Mode</button>
            </div>
        </div>
    </nav>

    <div class="page-wrap">
    {% if navIndex > 0 %}
    <a href="/" class="back-link">&larr; Back to Home</a>
    {% endif %}
    {{ content | safe }}
    </div>

    <footer class="footer">
        <div class="container">
            <p class="copyright">© 2026 Prakhar Singh</p>
        </div>
    </footer>

    <script src="/js/animation.js"></script>
    <script src="/js/feature.js"></script>
    <script src="/js/theme.js"></script>
</body>
</html>
